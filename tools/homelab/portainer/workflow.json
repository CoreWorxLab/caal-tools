    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\nconst deleted = data.ImagesDeleted || [];\nconst spaceReclaimed = data.SpaceReclaimed || 0;\n\nconst untagged = deleted.filter(d => d.Untagged).length;\nconst removed = deleted.filter(d => d.Deleted).length;\n\nconst mb = (spaceReclaimed / 1024 / 1024).toFixed(1);\nconst gb = (spaceReclaimed / 1024 / 1024 / 1024).toFixed(2);\nconst sizeStr = spaceReclaimed > 1073741824 ? `${gb} GB` : `${mb} MB`;\n\nif (removed === 0 && untagged === 0) {\n  return [{ json: { message: 'No unused images to remove.', removed: 0, space_reclaimed: '0 MB' } }];\n}\n\nconst message = `Pruned ${removed} images (${untagged} untagged). Reclaimed ${sizeStr}.`;\nreturn [{ json: { message, removed, untagged, space_reclaimed: sizeStr, bytes_reclaimed: spaceReclaimed } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        700
      ],
      "name": "Format Prune",
      "id": "portainer-fmpr-0012-0000-000000000012"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\nconst containers = Array.isArray(data) ? data : (Array.isArray($input.all().map(i => i.json)) ? $input.all().map(i => i.json) : []);\n\nif (containers.length === 0) {\n  return [{ json: { message: 'No containers found.', count: 0, containers: [] } }];\n}\n\nconst formatted = containers.map((c, i) => {\n  const name = (c.Names && c.Names[0]) ? c.Names[0].replace(/^\\//, '') : c.Id?.substring(0, 12) || 'unknown';\n  const image = (c.Image || '').split(':')[0].split('/').pop();\n  const state = (c.State || 'unknown').toLowerCase();\n  const status = c.Status || '';\n  return { number: i + 1, name, image, state, status };\n});\n\nconst running = formatted.filter(c => c.state === 'running').length;\nconst stopped = formatted.filter(c => c.state !== 'running').length;\n\nlet message = `${formatted.length} containers (${running} running, ${stopped} stopped): `;\nformatted.forEach(c => {\n  message += `${c.number}. ${c.name} [${c.image}] (${c.state}). `;\n});\n\nreturn [{ json: { message: message.trim(), count: formatted.length, running, stopped, containers: formatted } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        -500
      ],
      "name": "Format Containers",
      "id": "portainer-fmtc-0011-0000-000000000011"
    },
    {
      "parameters": {
        "jsCode": "const container = $('Parse Parameters').item.json.container;\nreturn [{ json: { message: `Container ${container} started.`, success: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        -300
      ],
      "name": "Format Start",
      "id": "portainer-fmst-0012-0000-000000000012"
    },
    {
      "parameters": {
        "jsCode": "const container = $('Parse Parameters').item.json.container;\nreturn [{ json: { message: `Container ${container} stopped.`, success: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        -100
      ],
      "name": "Format Stop",
      "id": "portainer-fmsp-0013-0000-000000000013"
    },
    {
      "parameters": {
        "jsCode": "const container = $('Parse Parameters').item.json.container;\nreturn [{ json: { message: `Container ${container} restarted.`, success: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        100
      ],
      "name": "Format Restart",
      "id": "portainer-fmrs-0014-0000-000000000014"
    },
    {
      "parameters": {
        "jsCode": "const container = $('Parse Parameters').item.json.container;\nconst tail = $('Parse Parameters').item.json.tail;\nconst rawData = $input.item.json;\n\nlet logText = '';\nif (typeof rawData === 'string') {\n  logText = rawData;\n} else if (rawData.data) {\n  logText = rawData.data;\n} else {\n  logText = JSON.stringify(rawData);\n}\n\n// Clean Docker log stream header bytes (8-byte prefix per line)\nconst lines = logText.split('\\n').map(line => {\n  if (line.length > 8) {\n    const cleaned = line.substring(8);\n    return cleaned;\n  }\n  return line;\n}).filter(l => l.trim());\n\nconst limited = lines.slice(-tail);\nconst message = `Last ${limited.length} log lines for ${container}:\\n${limited.join('\\n')}`;\n\nreturn [{ json: { message, container, line_count: limited.length, logs: limited } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        300
      ],
      "name": "Format Logs",
      "id": "portainer-fmlg-0015-0000-000000000015"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\nconst stacks = Array.isArray(data) ? data : [];\n\nif (stacks.length === 0) {\n  return [{ json: { message: 'No stacks found.', count: 0, stacks: [] } }];\n}\n\nconst formatted = stacks.map((s, i) => ({\n  number: i + 1,\n  name: s.Name || 'unknown',\n  id: s.Id,\n  status: s.Status === 1 ? 'active' : 'inactive',\n  type: s.Type === 1 ? 'swarm' : s.Type === 2 ? 'compose' : 'unknown'\n}));\n\nconst active = formatted.filter(s => s.status === 'active').length;\nlet message = `${formatted.length} stacks (${active} active): `;\nformatted.forEach(s => {\n  message += `${s.number}. ${s.name} (${s.status}, ${s.type}). `;\n});\n\nreturn [{ json: { message: message.trim(), count: formatted.length, stacks: formatted } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        500
      ],
      "name": "Format Stacks",
      "id": "portainer-fmsk-0016-0000-000000000016"
    },
    {
      "parameters": {
        "jsCode": "const errorData = $input.item.json;\n\nif (errorData.error === true && errorData.message) {\n  return [{ json: { message: errorData.message, error: true } }];\n}\n\nlet errorMsg = errorData.message || errorData.error || 'Unknown error';\nif (typeof errorMsg === 'object') {\n  errorMsg = errorMsg.message || JSON.stringify(errorMsg);\n}\nerrorMsg = String(errorMsg);\n\nif (errorMsg.includes('ECONNREFUSED') || errorMsg.includes('ETIMEDOUT')) {\n  errorMsg = 'Cannot connect to Portainer. Is it running?';\n} else if (errorMsg.includes('401') || errorMsg.includes('Unauthorized') || errorMsg.includes('auth')) {\n  errorMsg = 'Portainer authentication failed. Check the API key.';\n} else if (errorMsg.includes('404') || errorMsg.includes('not found') || errorMsg.includes('No such container')) {\n  errorMsg = 'Container not found. Check the name or ID.';\n}\n\nreturn [{ json: { message: 'Portainer error: ' + errorMsg, error: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        0
      ],
