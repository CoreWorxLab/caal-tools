    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\nconst q = data.queue || data;\nconst slots = q.slots || [];\n\nif (slots.length === 0) {\n  return [{ json: { message: 'Download queue is empty.', count: 0, speed: q.speed || '0', downloads: [] } }];\n}\n\nconst downloads = slots.map((s, i) => ({\n  number: i + 1,\n  name: s.filename,\n  status: s.status,\n  progress: parseInt(s.percentage) || 0,\n  size: s.size || 'Unknown',\n  remaining: s.sizeleft || 'Unknown',\n  eta: s.timeleft || 'Unknown',\n  category: s.cat || 'None'\n}));\n\nlet message = `${slots.length} download${slots.length !== 1 ? 's' : ''} in queue at ${q.speed || '0'}/s. `;\ndownloads.slice(0, 5).forEach(d => {\n  message += `${d.number}. ${d.name} - ${d.progress}% (${d.remaining} left). `;\n});\n\nreturn [{ json: { message: message.trim(), count: slots.length, speed: q.speed || '0', paused: q.paused || false, downloads } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        -500
      ],
      "name": "Format Queue",
      "id": "sabnzbd-fmtq-0011-0000-000000000011"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\nconst h = data.history || data;\nconst slots = h.slots || [];\n\nif (slots.length === 0) {\n  return [{ json: { message: 'No recent download history.', count: 0, history: [] } }];\n}\n\nconst history = slots.map((s, i) => {\n  const completed = s.completed ? new Date(s.completed * 1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : 'Unknown';\n  return {\n    number: i + 1,\n    name: s.name,\n    status: s.status,\n    size: s.size || 'Unknown',\n    completed: completed,\n    category: s.category || 'None',\n    fail_message: s.fail_message || null\n  };\n});\n\nconst completed = history.filter(h => h.status === 'Completed').length;\nconst failed = history.filter(h => h.status === 'Failed').length;\n\nlet message = `${history.length} recent downloads. `;\nif (completed > 0) message += `${completed} completed. `;\nif (failed > 0) message += `${failed} failed. `;\nhistory.slice(0, 5).forEach(h => {\n  message += `${h.number}. ${h.name} - ${h.status}`;\n  if (h.fail_message) message += ` (${h.fail_message})`;\n  message += '. ';\n});\n\nreturn [{ json: { message: message.trim(), count: history.length, completed_count: completed, failed_count: failed, history } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        -300
      ],
      "name": "Format History",
      "id": "sabnzbd-fmth-0012-0000-000000000012"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\nconst q = data.queue || data;\n\nconst paused = q.paused || false;\nconst speed = q.speed || '0';\nconst status = q.status || 'Unknown';\nconst queueSize = q.sizeleft || '0 B';\nconst queueCount = parseInt(q.noofslots_total) || 0;\nconst disk1 = q.diskspace1 ? parseFloat(q.diskspace1).toFixed(1) : 'Unknown';\nconst disk1Total = q.diskspacetotal1 ? parseFloat(q.diskspacetotal1).toFixed(1) : 'Unknown';\nconst disk2 = q.diskspace2 ? parseFloat(q.diskspace2).toFixed(1) : 'Unknown';\nconst disk2Total = q.diskspacetotal2 ? parseFloat(q.diskspacetotal2).toFixed(1) : 'Unknown';\nconst speedLimit = q.speedlimit || '0';\nconst eta = q.timeleft || '0:00:00';\n\nlet message = `SABnzbd is ${paused ? 'paused' : status.toLowerCase()}. `;\nif (!paused && speed !== '0') message += `Speed: ${speed}/s. `;\nif (speedLimit !== '0' && speedLimit !== '100') message += `Speed limit: ${speedLimit}%. `;\nmessage += `${queueCount} item${queueCount !== 1 ? 's' : ''} in queue`;\nif (queueCount > 0) message += ` (${queueSize} remaining, ETA ${eta})`;\nmessage += `. Download disk: ${disk1} GB free of ${disk1Total} GB. Complete disk: ${disk2} GB free of ${disk2Total} GB.`;\n\nreturn [{ json: { message, status, paused, speed, speed_limit: speedLimit, queue_count: queueCount, queue_remaining: queueSize, eta, disk_download_free_gb: disk1, disk_complete_free_gb: disk2 } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        -100
      ],
      "name": "Format Status",
      "id": "sabnzbd-fmts-0013-0000-000000000013"
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { message: 'Download queue has been paused.', success: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        100
      ],
      "name": "Format Pause",
      "id": "sabnzbd-fmtp-0014-0000-000000000014"
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { message: 'Download queue has been resumed.', success: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        300
      ],
      "name": "Format Resume",
      "id": "sabnzbd-fmtr-0015-0000-000000000015"
    },
    {
      "parameters": {
        "jsCode": "const speed = $('Parse Parameters').item.json.speed;\nconst message = speed === '0' ? 'Speed limit removed. Downloading at full speed.' : `Speed limit set to ${speed}.`;\nreturn [{ json: { message, success: true, speed_limit: speed } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        500
      ],
      "name": "Format Speed Limit",
      "id": "sabnzbd-fmtl-0016-0000-000000000016"
    },
    {
      "parameters": {
        "jsCode": "const errorData = $input.item.json;\nlet errorMsg = errorData.message || errorData.error || 'Unknown error';\nif (typeof errorMsg === 'object') {\n  errorMsg = errorMsg.message || JSON.stringify(errorMsg);\n}\nerrorMsg = String(errorMsg);\n\nif (errorMsg.includes('ECONNREFUSED') || errorMsg.includes('ETIMEDOUT')) {\n  errorMsg = 'Cannot connect to SABnzbd. Is it running?';\n} else if (errorMsg.includes('401') || errorMsg.includes('api-key')) {\n  errorMsg = 'SABnzbd authentication failed. Check the API key.';\n}\n\nreturn [{ json: { message: 'SABnzbd error: ' + errorMsg, error: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        0
